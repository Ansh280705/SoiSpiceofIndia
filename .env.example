# EmailJS General Settings
VITE_SERVICE_ID=your_service_id_here
VITE_PUBLIC_KEY=your_public_key_here

# EmailJS Template IDs 
VITE_ORDER_TEMPLATE_ID=your_order_template_id_here    # Used for Orders
VITE_INQUIRY_TEMPLATE_ID=your_inquiry_template_id_here # Used for Contact Us

# Razorpay Settings
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Database Settings (Neon DB)
# Replace with your actual connection string from Neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require